<Page x:Class="LitLink_FinalProject.Pages.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LitLink_FinalProject.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource = "/Covers/Login.png" Stretch = "UniformToFill"/>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="170"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="55"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <TextBox x:Name = "EmailInput" 
                 Grid.Row="1"
                 Grid.Column="1"
                 HorizontalAlignment="Left"
                 Width = "230" 
                 Height = "40"
                 Text = "litlink@gmail.com"
                 Foreground  ="#6c3134" 
                 FontSize = "19" 
                 FontFamily="/Fonts/#Alex Brush"
                 Background="Transparent"
                 BorderThickness="0"
                 VerticalContentAlignment="Center"
                 GotFocus="EmailInput_GotFocus" 
                 LostFocus="EmailInput_LostFocus"/>
        <Grid Grid.Row="3" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="PasswordInput" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Foreground="#6c3134" 
                         FontFamily="/Fonts/Alex Brush"
                         FontSize="19"
                         VerticalContentAlignment="Center"
                         PasswordChanged="PasswordInput_PasswordChanged"/>
            <TextBox x:Name="VisiblePasswordInput" 
                     Visibility="Collapsed"
                     Background="Transparent" 
                     BorderThickness="0"
                     Foreground="#6c3134" 
                     FontFamily="/Fonts/Roboto Slab"
                     FontSize="19"
                     VerticalContentAlignment="Center"/>
            <TextBlock x:Name="PasswordPlaceholder" 
                       Text="****" 
                       Foreground="#6c3134" 
                       FontSize="19" 
                       FontFamily="/Fonts/Alex Brush"
                       VerticalAlignment="Center" 
                       IsHitTestVisible="False"/>
            <Button x:Name="TogglePasswordButton" 
                    Grid.Column="1"
                    Content="👁" 
                    HorizontalAlignment="Right" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    Cursor="Hand" 
                    Opacity="0.5"
                    PreviewMouseDown="TogglePasswordButton_PreviewMouseDown"
                    PreviewMouseUp="TogglePasswordButton_PreviewMouseUp"/>
        </Grid>
        <TextBlock Grid.Row="4" Grid.Column="1">
            <Hyperlink Click = "Navigate_ResetPass"
                       FontFamily = "/Fonts/#Roboto Slab"
                       FontSize = "12"
                       Foreground = "#6C3134">
                Forgot Password?
            </Hyperlink>
        </TextBlock>
        <Button x:Name = "loginButton"
                Content = "Login"
                Grid.Row="6"
                Grid.Column="1"
                Width="120" 
                Height="40" 
                FontFamily = "/Fonts/#Alex Brush"
                FontSize = "30"
                Background = "#aa3954" 
                Foreground = "#F6DCDA"
                Click = "Login_Click"/>
        <StackPanel Orientation = "Horizontal" HorizontalAlignment = "Center" Grid.Row="7" Grid.Column="1">
            <TextBlock FontFamily = "/Fonts/#Roboto Slab"
                       FontSize = "12"
                       Foreground = "#F27F9B"
                       Text = "Don't have an account? "/>
            <TextBlock>
                 <Hyperlink Click = "Navigate_SignUp"
                            FontFamily = "/Fonts/#Roboto Slab"
                            FontSize = "12"
                            Foreground = "#6C3134">
                     Sign Up
                 </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>
