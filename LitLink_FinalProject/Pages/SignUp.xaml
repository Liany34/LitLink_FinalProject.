<Page x:Class="LitLink_FinalProject.Pages.SignUp"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LitLink_FinalProject.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SignUp"
      Background = "White">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource = "/Covers/SignUp.png"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="280"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="600"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="17"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="9"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="9"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="17"/>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="25"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="FirstNameInput"
                         Grid.Row="0"
                         HorizontalAlignment="Left"
                         Width="230"
                         Height="25"
                         Text="First Name"
                         Foreground="#6c3134"
                         FontSize="14"
                         FontFamily="/Fonts/#Alex Brush"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalContentAlignment="Center"
                         GotFocus="FirstNameInput_GotFocus"
                         LostFocus="FirstNameInput_LostFocus"/>
                <TextBox x:Name="LastNameInput"
                         Grid.Row="2"
                         HorizontalAlignment="Left"
                         Width="230"
                         Height="25"
                         Text="Last Name"
                         Foreground="#6c3134"
                         FontSize="14"
                         FontFamily="/Fonts/#Alex Brush"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalContentAlignment="Center"
                         GotFocus="LastNameInput_GotFocus"
                         LostFocus="LastNameInput_LostFocus"/>
                <TextBox x:Name="PhoneInput"
                         Grid.Row="4"
                         HorizontalAlignment="Left"
                         Width="230"
                         Height="25"
                         Text="000-0000000"
                         Foreground="#6c3134"
                         FontSize="14"
                         FontFamily="/Fonts/#Alex Brush"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalContentAlignment="Center"
                         GotFocus="PhoneInput_GotFocus"
                         LostFocus="PhoneInput_LostFocus"/>
                <TextBlock x:Name="InvaildPhone"
                           Text="Invalid phone Number" 
                           Grid.Row="5"
                           Foreground="#aa3954" 
                           FontSize="9" 
                           Visibility="Collapsed"
                           HorizontalAlignment="Left"
                           FontFamily="/Fonts/#Roboto Slab"
                           VerticalAlignment="Top"/>
                <TextBox x:Name = "EmailInput" 
                         Grid.Row="7"
                         HorizontalAlignment="Left"
                         Width = "230" 
                         Height = "25"
                         Text = "litlink@gmail.com"
                         Foreground  ="#6c3134" 
                         FontSize = "19" 
                         FontFamily="/Fonts/#Alex Brush"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalContentAlignment="Center"
                         GotFocus="EmailInput_GotFocus" 
                         LostFocus="EmailInput_LostFocus"/>
                <TextBlock x:Name="InvalidEmail"
                           Text="Invalid email format" 
                           Grid.Row="8"
                           Foreground="#aa3954" 
                           FontSize="9" 
                           Visibility="Collapsed"
                           HorizontalAlignment="Left"
                           FontFamily="/Fonts/#Roboto Slab"
                           VerticalAlignment="Top"/>
                <PasswordBox x:Name="PasswordInput" 
                             Background="Transparent" 
                             BorderThickness="0"
                             Foreground="#6c3134" 
                             FontFamily="/Fonts/Alex Brush"
                             FontSize="19"
                             Grid.Row="10"
                             VerticalContentAlignment="Center"
                             PasswordChanged="PasswordInput_PasswordChanged"/>
                <TextBox x:Name="VisiblePasswordInput" 
                         Visibility="Collapsed"
                         Background="Transparent" 
                         BorderThickness="0"
                         Foreground="#6c3134" 
                         FontFamily="/Fonts/Roboto Slab"
                         FontSize="19"
                         Grid.Row="10"
                         VerticalContentAlignment="Center"/>
                <TextBlock x:Name="PasswordPlaceholder" 
                           Text="****" 
                           Foreground="#6c3134" 
                           FontSize="19" 
                           Grid.Row="10"
                           FontFamily="/Fonts/Alex Brush"
                           VerticalAlignment="Center" 
                           IsHitTestVisible="False"/>
                <Button x:Name="TogglePasswordButton" 
                        Grid.Row="10"
                        Content="👁" 
                        HorizontalAlignment="Right" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Cursor="Hand" 
                        Opacity="0.5"
                        PreviewMouseDown="TogglePasswordButton_PreviewMouseDown"
                        PreviewMouseUp="TogglePasswordButton_PreviewMouseUp"/>
                <PasswordBox x:Name="ReenterInput" 
                             Background="Transparent" 
                             BorderThickness="0"
                             Foreground="#6c3134" 
                             FontFamily="/Fonts/Alex Brush"
                             FontSize="19"
                             Grid.Row="12"
                             VerticalContentAlignment="Center"
                             PasswordChanged="ReenterInput_PasswordChanged"/>
                <TextBox x:Name="VisibleReenterInput" 
                         Visibility="Collapsed"
                         Grid.Row="12"
                         Background="Transparent" 
                         BorderThickness="0"
                         Foreground="#6c3134" 
                         FontFamily="/Fonts/Roboto Slab"
                         FontSize="19"
                         VerticalContentAlignment="Center"/>
                <TextBlock x:Name="ReenterPlaceholder" 
                           Text="****" 
                           Grid.Row="12"
                           Foreground="#6c3134" 
                           FontSize="19" 
                           FontFamily="/Fonts/Alex Brush"
                           VerticalAlignment="Center" 
                           IsHitTestVisible="False"/>
                <Button x:Name="ToggleReenterButton"
                        Grid.Row="12"
                        Content="👁" 
                        HorizontalAlignment="Right" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        Cursor="Hand" 
                        Opacity="0.5"
                        PreviewMouseDown="ToggleReenterButton_PreviewMouseDown"
                        PreviewMouseUp="ToggleReenterButton_PreviewMouseUp"/>
                <TextBlock x:Name="DiffPass"
                           Grid.Row="14"
                           Text="Passwords do not match"
                           FontFamily="/Fonts/#Roboto Slab"
                           FontSize="11"
                           Foreground="#aa3954"
                           Visibility="Collapsed"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"/>
                <TextBox x:Name="UsernameInput"
                         Grid.Row="15"
                         HorizontalAlignment="Left"
                         Width="230"
                         Height="25"
                         Text="Username"
                         Foreground="#6c3134"
                         FontSize="14"
                         FontFamily="/Fonts/#Alex Brush"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalContentAlignment="Center"
                         GotFocus="UsernameInput_GotFocus"
                         LostFocus="UsernameInput_LostFocus"/>
            </Grid>
            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="15"/>
                </Grid.RowDefinitions>
                <DatePicker x:Name="BirthDatePicker"
                            Grid.Row="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Width="170"
                            Height="25"
                            Foreground="#6c3134"
                            FontSize="14"
                            FontFamily="/Fonts/#Alex Brush"
                            Background="Transparent"
                            BorderThickness="0"/>
                <TextBlock x:Name="InvalidBirthDate"
                           Text="You must choose your birthdate" 
                           Grid.Row="2"
                           Foreground="#aa3954" 
                           FontSize="11" 
                           Visibility="Collapsed"
                           HorizontalAlignment="Left"
                           FontFamily="/Fonts/#Roboto Slab"
                           VerticalAlignment="Top"/>
            </Grid>
        </Grid>
        <Button x:Name="SignUpButton"
                Content = "Sign Up"
                Grid.Row="2"
                Grid.Column="1"
                Width="120" 
                Height="40" 
                HorizontalAlignment="Center"
                Background="#aa3954"
                Foreground="White"
                FontFamily="/Fonts/#Alex Brush"
                FontSize="20"
                BorderThickness="0"
                Cursor="Hand"
                Click="SignUpButton_Click"/>
    </Grid>
</Page>
