<Page x:Class="LitLink_FinalProject.Pages.ResetPass"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LitLink_FinalProject.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ResetPass">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource = "/Covers/ResetPass.png" Stretch = "UniformToFill"/>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="170"/>
            <RowDefinition Height="135"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="130"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="55"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <PasswordBox x:Name="PasswordInput" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Foreground="#6c3134" 
                         FontFamily="/Fonts/Alex Brush"
                         FontSize="19"
                         VerticalContentAlignment="Center"
                         PasswordChanged="PasswordInput_PasswordChanged"/>
            <TextBox x:Name="VisiblePasswordInput" 
                     Visibility="Collapsed"
                     Background="Transparent" 
                     BorderThickness="0"
                     Foreground="#6c3134" 
                     FontFamily="/Fonts/Roboto Slab"
                     FontSize="19"
                     VerticalContentAlignment="Center"/>
            <TextBlock x:Name="PasswordPlaceholder" 
                       Text="****" 
                       Foreground="#6c3134" 
                       FontSize="19" 
                       FontFamily="/Fonts/Alex Brush"
                       VerticalAlignment="Center" 
                       IsHitTestVisible="False"/>
            <Button x:Name="TogglePasswordButton" 
                    Grid.Column="1"
                    Content="👁" 
                    HorizontalAlignment="Right" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    Cursor="Hand" 
                    Opacity="0.5"
                    PreviewMouseDown="TogglePasswordButton_PreviewMouseDown"
                    PreviewMouseUp="TogglePasswordButton_PreviewMouseUp"/>
            <PasswordBox x:Name="ReenterInput" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Foreground="#6c3134" 
                         FontFamily="/Fonts/Alex Brush"
                         FontSize="19"
                         Grid.Row="2"
                         VerticalContentAlignment="Center"
                         PasswordChanged="ReenterInput_PasswordChanged"/>
            <TextBox x:Name="VisibleReenterInput" 
                     Visibility="Collapsed"
                     Grid.Row="2"
                     Background="Transparent" 
                     BorderThickness="0"
                     Foreground="#6c3134" 
                     FontFamily="/Fonts/Roboto Slab"
                     FontSize="19"
                     VerticalContentAlignment="Center"/>
            <TextBlock x:Name="ReenterPlaceholder" 
                       Text="****" 
                       Grid.Row="2"
                       Foreground="#6c3134" 
                       FontSize="19" 
                       FontFamily="/Fonts/Alex Brush"
                       VerticalAlignment="Center" 
                       IsHitTestVisible="False"/>
            <Button x:Name="ToggleReenterButton" 
                    Grid.Column="1"
                    Grid.Row="2"
                    Content="👁" 
                    HorizontalAlignment="Right" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    Cursor="Hand" 
                    Opacity="0.5"
                    PreviewMouseDown="ToggleReenterButton_PreviewMouseDown"
                    PreviewMouseUp="ToggleReenterButton_PreviewMouseUp"/>
        </Grid>
        <TextBlock x:Name="DiffPass"
                   Grid.Row="2"
                   Grid.Column="1"
                   Text="Passwords do not match"
                   FontFamily="/Fonts/#Roboto Slab"
                   FontSize="12"
                   Foreground="#aa3954"
                   Visibility="Collapsed"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Bottom"/>
        <Button x:Name="ResetPassword"
                Content = "Reset"
                Grid.Row="3"
                Grid.Column="1"
                Width="120" 
                Height="40" 
                FontFamily = "/Fonts/#Alex Brush"
                FontSize = "30"
                Background = "#aa3954" 
                Foreground = "#F6DCDA"
                Click="ResetPassword_Click"/>
    </Grid>
</Page>
