<UserControl x:Class="LitLink_FinalProject.UserControls.BookUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LitLink_FinalProject.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#E3DBCC">
    <Border Background="White" CornerRadius="20" Padding="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="LightGray" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="2" Grid.Column="0" CornerRadius="10" 
                    Background="#F0F0F0" Height="250" VerticalAlignment="Top" Margin="0,0,20,0">
                <Image Source="{Binding BookImage, Converter={StaticResource BytesToImageConverter}}" 
                       Stretch="UniformToFill"/>
            </Border>

            <StackPanel Grid.Column="1" Grid.Row="0">
                <TextBlock Text="{Binding BookName}" FontSize="24" FontWeight="Bold" Foreground="#333"/>
                <TextBlock Text="{Binding AuthorName}" FontSize="16" Foreground="Gray" Margin="0,5"/>

                <Border Background="#FFF0F5" CornerRadius="10" Padding="10" Margin="0,10">
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="14" Height="100"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,10">
                <TextBlock Text="Reviews" FontWeight="SemiBold" FontSize="18"/>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="⭐⭐⭐⭐" FontSize="18"/>
                </StackPanel>

                <Border BorderBrush="#EEE" BorderThickness="0,1,0,0" Padding="5">
                    <Grid>
                        <Ellipse Width="30" Height="30" Fill="Pink" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding TopReviewerName}" Margin="40,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" 
                        HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Buy" Style="{StaticResource CoquetteButtonStyle}" Width="80" Margin="5"/>
                <Button Content="Add to list" Style="{StaticResource SecondaryButtonStyle}" Width="100" Margin="5"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
